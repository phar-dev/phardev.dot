{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "default_agent": "phardev",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "engram": {
      "command": [
        "/home/linuxbrew/.linuxbrew/Cellar/engram/1.12.0/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    }
  },
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "litellm",
      "options": {
        "baseURL": "{env:CUSTOM_PROVIDER}"
      },
      "models": {
        "phardev/coder": {
          "name": "Main",
          "options": {
            "temperature": 0.5,
            "maxTokens": 32768
          }
        },
        "phardev/testing": {
          "name": "Testing",
          "options": {
            "temperature": 0.7,
            "maxTokens": 64000
          }
        }
      }
    }
  },

  "model": "opencode/minimax-m2.5-free",
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "allow",
      "git push *": "ask",
      "git push": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/secrets/**": "deny",
      "**/credentials.json": "deny"
    }
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  }
}
