{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "default_agent": "phardev",
  "disabled_providers": [],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "engram": {
      "command": [
        "/home/linuxbrew/.linuxbrew/Cellar/engram/1.14.12/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "allow",
      "git push *": "ask",
      "git push": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/secrets/**": "deny",
      "**/credentials.json": "deny"
    }
  },
  "provider": {
    "litellm": {
      "name": "Phardev",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://route.phardev.site/v1"
      },
      "models": {
        "phardev/coder": {
          "name": "main"
        },
        "phardev/testing": {
          "name": "testing"
        }
      }
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**"
    ]
  }
}